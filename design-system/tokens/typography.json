{
  "font": {
    "family": {
      "body": { "$value": "'Rubik Variable', 'Rubik', sans-serif", "$type": "fontFamily", "$description": "Primary font — Rubik variable font, self-hosted" }
    },
    "size": {
      "$type": "dimension",
      "heading": { "$value": "16px", "$description": "City names, driver name, page titles, CTA buttons" },
      "body": { "$value": "13px", "$description": "Time, date, price, seats, pills, labels, nav, helper text" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400, "$description": "Body text — everything at 11px" },
      "bold": { "$value": 700, "$description": "Headings — everything at 15px" }
    },
    "lineHeight": {
      "$type": "number",
      "tight": { "$value": 1.6, "$description": "Compact text — declined message" },
      "normal": { "$value": 1.7, "$description": "Standard body text" },
      "relaxed": { "$value": 1.8, "$description": "Paragraph text — descriptions, notes, confirm modal" },
      "loose": { "$value": 2.0, "$description": "Input fields — rides/[id] input lineHeight" }
    },
    "letterSpacing": {
      "$type": "dimension",
      "tight": { "$value": "-0.5px", "$description": "App name لیمۆ heading" },
      "normal": { "$value": "0px", "$description": "Default — most text" },
      "wide": { "$value": "1px", "$description": "License card labels, star ratings" },
      "wider": { "$value": "1.5px", "$description": "License card region label" }
    },
    "textShadow": {
      "brandSm": { "$value": "2px 2px 0 #E8470A", "$type": "shadow", "$description": "App name text shadow — home page h1" },
      "brandLg": { "$value": "3px 3px 0 #E8470A", "$type": "shadow", "$description": "Large brand text shadow — reserved" }
    }
  }
}
